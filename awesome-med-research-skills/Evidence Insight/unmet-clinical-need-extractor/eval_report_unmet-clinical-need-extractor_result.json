  "key_strengths": [
    "Specific clinical pain point taxonomy prevents vague 'important disease' framing from passing as unmet need",
    "Evidence grounding requirement distinguishes real care gaps from advocacy statements",
    "Distinction between true care gaps and generic statements of importance is rigorously enforced",
    "Magnitude and actionability assessment per unmet need enables research prioritization"
  ],
  "recommendations": [
    {
      "priority": "P1",
      "title": "One assertion failure: generic 'limited treatment options' accepted as unmet need",
      "observed_in": [
        4
      ],
      "problem": "In an edge case, 'limited treatment options for this disease' was accepted as an unmet clinical need without being pushed toward a more specific gap definition.",
      "root_cause": "Unmet need specificity check exists but the threshold for what constitutes 'specific enough' is not clearly defined.",
      "fix": "Add a specificity check: 'limited treatment options' is not an unmet need by itself. Require the user to specify: (1) what treatments exist, (2) what outcomes are inadequate, and (3) which patient population is most affected. Then define the unmet need from these specifics."
    },
    {
      "priority": "P2",
      "title": "No explicit guidance on distinguishing patient-level from system-level unmet needs",
      "observed_in": [],
      "problem": "The skill extracts clinical unmet needs but does not always distinguish between patient-level gaps (e.g., poor survival rates) and system-level gaps (e.g., inadequate monitoring infrastructure).",
      "root_cause": "Unmet need taxonomy focuses on clinical categories but not on the level at which the gap operates.",
      "fix": "Add a level classification: distinguish patient-level unmet needs (affecting individual clinical outcomes) from system-level unmet needs (affecting care delivery, access, or monitoring) as these require different research approaches."
    }
  ]
