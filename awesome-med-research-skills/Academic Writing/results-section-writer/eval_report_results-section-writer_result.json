  "key_strengths": [
    "Mandatory prerequisite check — recommends results-section-structurer when structure is absent",
    "Evidence boundary preservation during writing prevents prose inflation of results",
    "Table/figure reference integration ensures prose and visual alignment",
    "Statistical result reporting discipline (effect sizes + confidence intervals preferred over p-values alone)"
  ],
  "recommendations": [
    {
      "priority": "P1",
      "title": "Two assertion failures from statistical overclaiming in prose",
      "observed_in": [
        2,
        4
      ],
      "problem": "In two test cases, statistical significance was described with language implying clinical significance ('significantly better outcome') without effect size context.",
      "root_cause": "Statistical wording check exists but the clinical significance vs statistical significance distinction is not always enforced.",
      "fix": "Add a hard rule: never use 'significantly' or 'significant' without pairing it with the effect size and confidence interval in the same sentence or the immediately following sentence."
    },
    {
      "priority": "P2",
      "title": "No explicit handling of negative or null primary results",
      "observed_in": [],
      "problem": "The skill writes results from positive findings well but does not have specific guidance for presenting null or negative primary results.",
      "root_cause": "Most training scenarios involve positive findings.",
      "fix": "Add a null-results writing note: for null primary results, present the confidence interval and effect size prominently rather than emphasizing the p-value. State that a well-powered null result is informative, not a failure."
    }
  ]
