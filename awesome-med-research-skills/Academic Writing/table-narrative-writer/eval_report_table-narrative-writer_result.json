  "key_strengths": [
    "Pattern-first narrative approach prevents number-dumping and focuses reader attention on meaningful contrasts",
    "Interpretation boundary enforcement prevents table narrative from overclaiming beyond displayed data",
    "Clinical vs statistical significance distinction in table narrative is rigorously applied",
    "Table type classification (baseline/outcome/subgroup/biomarker) enables appropriate narrative strategy"
  ],
  "recommendations": [
    {
      "priority": "P1",
      "title": "Two assertion failures from excessive number reporting rather than pattern focus",
      "observed_in": [
        2,
        3
      ],
      "problem": "In two test cases, the narrative report listed most table values individually rather than focusing on the 2-3 most meaningful patterns and contrasts.",
      "root_cause": "Pattern-first rule exists but enforcement is inconsistent when tables have many rows/columns.",
      "fix": "Add a hard limit: narrative should reference no more than 40% of the numeric values in any given table. Select the 2-4 most meaningful values for explicit mention; summarize the rest at the pattern level."
    },
    {
      "priority": "P2",
      "title": "No guidance on handling tables with missing data or multiple footnote categories",
      "observed_in": [],
      "problem": "When tables have missing data cells or multiple footnote explanations, the narrative sometimes ignores these important methodological signals.",
      "root_cause": "Narrative focus rules don't cover missing data handling in tables.",
      "fix": "Add a missing data rule: if any cell contains missing data, footnotes, or qualifiers, explicitly address these in the narrative and note their potential impact on the pattern interpretation."
    }
  ]
