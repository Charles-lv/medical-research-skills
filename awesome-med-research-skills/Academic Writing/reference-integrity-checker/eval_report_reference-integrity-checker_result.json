    {
      "priority": "P1",
      "title": "Two assertion failures from paraphrased conclusion wording accepted without flagging",
      "observed_in": [
        2,
        4
      ],
      "problem": "In two test cases, conclusion wording that was a paraphrase rather than a quote from the original paper was not identified as a potential accuracy risk.",
      "root_cause": "Reference integrity rules check for factual accuracy but may not flag loose paraphrases that subtly shift meaning.",
      "fix": "Add a paraphrase accuracy check: when a reference is cited for a specific claim, verify that the paraphrase preserves the original scope and evidence level. Flag any paraphrase that upgrades association language to causation language."
    },
