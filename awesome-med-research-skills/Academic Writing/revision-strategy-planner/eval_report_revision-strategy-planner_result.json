  "recommendations": [
    {
      "priority": "P1",
      "title": "No structured handling of contradictory reviewer comments",
      "observed_in": [],
      "problem": "When two reviewers give contradictory comments (e.g., one asks to add an analysis, another asks to remove it), the skill does not have a structured resolution protocol.",
      "root_cause": "Comment prioritization handles single-reviewer cases but not cross-reviewer conflicts.",
      "fix": "Add a cross-reviewer conflict resolution protocol: when reviewer comments conflict, recommend addressing the conflict transparently in the rebuttal, explaining the decision made and the scientific rationale."
    },
    {
      "priority": "P2",
      "title": "No explicit guidance on major vs minor revision distinction",
      "observed_in": [],
      "problem": "The skill handles both major and minor revisions but does not provide specific guidance on how the revision strategy should differ between the two.",
      "root_cause": "Description mentions both but does not specify strategy differences.",
      "fix": "Add a major vs minor revision note: for minor revisions, focus on clarification and wording. For major revisions, explicitly assess whether new experiments are feasible within the resubmission timeline and prioritize analyses that can be completed within that window."
    }
