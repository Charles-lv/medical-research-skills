  "recommendations": [
    {
      "priority": "P1",
      "title": "Two assertion failures from overinterpretation of weak study storylines",
      "observed_in": [
        3,
        4
      ],
      "problem": "When study logic is weak or absent, the generated graphical abstract sometimes implies stronger conclusions than the evidence supports.",
      "root_cause": "Overinterpretation-check rule exists but is not applied as rigorously to visual output as to text output.",
      "fix": "Add an explicit claim-boundary check to the visual generation step: every panel or block in the graphical abstract must correspond to a stated finding, not an implied or hoped conclusion."
    },
    {
      "priority": "P2",
      "title": "Mermaid flowchart fallback quality inconsistent",
      "observed_in": [
        2
      ],
      "problem": "Mermaid flowchart output varies significantly in quality and does not always represent the study logic accurately.",
      "root_cause": "No minimum Mermaid quality standard defined in SKILL.md.",
      "fix": "Add a Mermaid quality checklist: (1) all major study steps represented, (2) arrows show directional logic not just connection, (3) no more than 7 blocks for clarity."
