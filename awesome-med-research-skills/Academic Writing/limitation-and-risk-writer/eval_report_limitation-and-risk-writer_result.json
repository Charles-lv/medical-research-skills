  "key_strengths": [
    "Acknowledge→Impact→Mitigation/Future Direction three-part formula prevents dead-end limitation statements",
    "Context-specific framing for manuscript vs grant vs reviewer-rebuttal scenarios is a practical differentiator",
    "Limitation category taxonomy (design/sample/measurement/follow-up/validation/generalizability) is systematic",
    "Phrase bank for 'too dismissive' vs 'too catastrophizing' language helps calibrate appropriate tone"
  ],
  "recommendations": [
    {
      "priority": "P2",
      "title": "No guidance on limitation statement ordering within the paragraph",
      "observed_in": [],
      "problem": "Multiple limitations are written individually but no guidance is given on how to sequence them (most important first vs design before measurement vs grouped by impact level).",
      "root_cause": "Formula covers individual statements but not the collective paragraph structure.",
      "fix": "Add a sequencing note: order limitations from highest to lowest impact on the primary conclusion; group related limitations (e.g., all sample limitations together); end with a future-direction statement rather than a weakness."
    }
  ]
